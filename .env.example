# ---- Backend environment ----

# Postgres connection string.
# IMPORTANT: the legacy Supabase DIRECT host (db.<ref>.supabase.co) is IPv4-deprecated
# and may not resolve. Use the Supabase **connection pooler** string instead, e.g.:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# (Supabase dashboard → Project Settings → Database → Connection string → "Session pooler")
SUPABASE_CONNECTION_STRING=postgresql://user:password@host:5432/postgres

# Set to "false" only for a local Postgres that does not speak SSL.
PGSSL=true

# Secret used to sign JWTs (use a long random string in production).
JWT_SECRET=change-me-to-a-long-random-secret

PORT=8000

# Must match the Vite dev server origin for cookies/CORS to work.
CORS_ORIGIN=http://localhost:5173
